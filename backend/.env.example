# ==========================
# Application
# ==========================

PORT=5000
NODE_ENV=development

# ==========================
# PostgreSQL
# ==========================
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public

DATABASE_URL="postgresql://postgres:your_password@localhost:5432/fasoconnect?schema=public"

# ==========================
# Authentication
# ==========================
# Generate a strong random secret, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET="replace_with_a_long_random_secret"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================
# Cloudinary
# ==========================
# Get these from https://cloudinary.com/console

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
