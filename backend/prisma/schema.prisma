// This is the Prisma schema for FasoConnect

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  ARTISAN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum RequestStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model User {
  id              String     @id @default(uuid())
  fullName        String
  email           String     @unique
  password        String
  phone           String?
  role            UserRole   @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)
  profilePicture  String?
  bio             String?
  city            String?
  country         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  artisanProfile  Artisan?
  requests        ServiceRequest[] @relation("CustomerRequests")
  assignments     Assignment[]     @relation("AssignedTo")
  reviewsGiven    Review[]         @relation("Reviewer")
  reviewsReceived Review[]         @relation("Reviewee")
  notifications   Notification[]
  favorites       FavoriteArtisan[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  artisans    Artisan[]
  requests    ServiceRequest[]
}

model Artisan {
  id               String   @id @default(uuid())
  userId           String   @unique
  categoryId       String
  experienceYears  Int
  hourlyRate       Decimal? @db.Decimal(10,2)
  latitude         Float?
  longitude        Float?
  availability     Boolean  @default(true)
  verified         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  requests         ServiceRequest[]
  assignments      Assignment[]
  favorites        FavoriteArtisan[]
}

model ServiceRequest {
  id              String        @id @default(uuid())
  customerId      String
  artisanId       String?
  categoryId      String
  title           String
  description     String
  location        String?
  latitude        Float?
  longitude       Float?
  budget          Decimal?      @db.Decimal(10,2)
  status          RequestStatus @default(PENDING)
  scheduledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer        User          @relation("CustomerRequests", fields: [customerId], references: [id], onDelete: Cascade)
  artisan         Artisan?      @relation(fields: [artisanId], references: [id], onDelete: SetNull)
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images          ServiceRequestImage[]
  assignments     Assignment[]
  reviews         Review[]
}

model ServiceRequestImage {
  id                String   @id @default(uuid())
  serviceRequestId  String
  imageUrl          String
  createdAt         DateTime @default(now())

  serviceRequest    ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
}

model Assignment {
  id                String           @id @default(uuid())
  serviceRequestId  String
  artisanId         String
  assignedBy        String
  status            AssignmentStatus @default(PENDING)
  message           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  serviceRequest    ServiceRequest   @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  artisan           Artisan          @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  assignedByUser    User             @relation("AssignedTo", fields: [assignedBy], references: [id], onDelete: Cascade)
}

model Review {
  id                String   @id @default(uuid())
  serviceRequestId  String
  reviewerId        String
  revieweeId        String
  rating            Int
  comment           String?
  createdAt         DateTime @default(now())

  serviceRequest    ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  reviewer          User           @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee          User           @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([serviceRequestId, reviewerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FavoriteArtisan {
  id        String   @id @default(uuid())
  userId    String
  artisanId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artisan   Artisan  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([userId, artisanId])
}
